    {
      "parameters": {
        "jsCode": "const editFields = $('Edit Fields').first().json;\nconst agg        = $input.first().json;\nconst surveyId   = agg.validatedResponses?.[0]?.surveyId || 1;\n\nconst getAnswer = (text) => {\n  const q = (editFields.responses || []).find(r => r.questionText === text);\n  return q?.answers?.[0] ?? null;\n};\nconst getAnswers = (text) => {\n  const q = (editFields.responses || []).find(r => r.questionText === text);\n  return q?.answers ?? [];\n};\n\nconst name           = getAnswer('Nombre');\nconst email          = getAnswer('Correo electrónico');\nconst topSymptom     = getAnswer('¿Cuál es el síntoma que más afecta tu calidad de vida hoy?');\nconst secondSymptom  = getAnswer('¿Cuál es el segundo síntoma que más te gustaría resolver?');\nconst timeProblem    = getAnswer('¿Hace cuánto tiempo este problema afecta tu vida?');\nconst previousHelp   = getAnswers('¿Qué has intentado para sentirte mejor?');\nconst intent         = getAnswer('Si pudiera resolver ___ en los próximos 30 días, sentiría que voy por buen camino.');\nconst budget         = getAnswer('Si encontraras una solución que realmente se adapte a tu situación, ¿qué inversión mensual considerarías razonable?');\nconst firstStep      = getAnswer('Si decidieras empezar por algo pequeño, ¿qué probarías primero?');\nconst learnStyle     = getAnswers('¿Cómo prefieres aprender?');\n\nconst structuredData = {\n  userId:              editFields.userId,\n  nombre:              name,\n  email:               email,\n  paisResidencia:      getAnswer('¿En qué país resides actualmente?'),\n  edad:                getAnswer('¿Cuál es tu edad?'),\n  situacionActual:     getAnswer('¿Cuál describe mejor tu situación actual?'),\n  sintomaPrincipal:    topSymptom,\n  segundoSintoma:      secondSymptom,\n  tiempoConElProblema: timeProblem,\n  preocupacionFutura:  getAnswer('Si este problema continúa igual durante otro año, ¿qué es lo que más te preocupa?'),\n  intentosAnteriores:  previousHelp,\n  inversionAnterior:   getAnswer('Aproximadamente, ¿cuánto has gastado intentando resolver este problema?'),\n  motivoAhora:         getAnswer('¿Qué fue lo que te hizo buscar ayuda justamente ahora?'),\n  intencion:           intent,\n  presupuestoMensual:  budget,\n  prefieriaEmpezarCon: firstStep,\n  formaDeAprender:     learnStyle\n};\n\nconst sistemaMessage =\n  '[SISTEMA] El usuario ha completado la Evaluación NutriBalance.\\n\\n' +\n  JSON.stringify(structuredData, null, 2);\n\nreturn [{\n  json: {\n    userId:         editFields.userId,\n    sourcePlatform: editFields.sourcePlatform,\n    channel:        editFields.channel,\n    surveyId,\n    extractedName:  name,\n    extractedEmail: email,\n    sistemaMessage,\n    rawPayload: {\n      userId:         editFields.userId,\n      sourcePlatform: editFields.sourcePlatform,\n      channel:        editFields.channel,\n      responses:      editFields.responses || []\n    }\n  }\n}];"
      },
