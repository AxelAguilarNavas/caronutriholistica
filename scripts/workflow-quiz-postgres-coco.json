      "id": "http-config-001",
      "name": "HTTP: Obtener config encuesta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [512, 448]
    },
    {
      "parameters": {
        "jsCode": "const editFields   = $('Edit Fields').first().json;\nconst surveyConfig = $input.first().json;\nconst responses    = editFields.responses || [];\nconst preguntas    = surveyConfig.Preguntas || [];\n\n// Verificar que la encuesta existe\nif (!surveyConfig.Encuestaid) {\n  return [{ json: {\n    isValid:  false,\n    httpCode: 404,\n    error:    'Encuesta no encontrada',\n    detail:   'No existe una encuesta activa con id ' + editFields.quizId\n  }}];\n}\n\nconst errors = [];\n\n// Mapa de respuestas por texto de pregunta\nconst responseMap = new Map();\nfor (const r of responses) {\n  responseMap.set(r.questionText, r.answers || []);\n}\n\n// Validar cada pregunta de la configuración\nfor (const pregunta of preguntas) {\n  const { PreguntaTexto, PreguntaTipo, obligatorio, opciones } = pregunta;\n  const answers = responseMap.get(PreguntaTexto) || [];\n\n  // Obligatoria sin respuesta\n  if (obligatorio && answers.length === 0) {\n    errors.push('Pregunta obligatoria sin respuesta: \"' + PreguntaTexto + '\"');\n    continue;\n  }\n\n  // Opción inválida en preguntas de selección\n  if (answers.length > 0 && PreguntaTipo !== 'text' && opciones && opciones.length > 0) {\n    const validas = new Set(opciones.map(o => o.opciontexto));\n    for (const ans of answers) {\n      if (!validas.has(ans)) {\n        errors.push('Opción inválida \"' + ans + '\" en pregunta: \"' + PreguntaTexto + '\"');\n      }\n    }\n  }\n}\n\nif (errors.length > 0) {\n  return [{ json: {\n    isValid:  false,\n    httpCode: 422,\n    error:    'Error de validación',\n    errors\n  }}];\n}\n\n// Retorna N items — uno por respuesta (ForEach implícito en n8n)\nreturn responses.map(r => ({\n  json: {\n    isValid:      true,\n    surveyId:     parseInt(surveyConfig.Encuestaid),\n    questionId:   r.questionId,\n    questionText: r.questionText,\n    answers:      r.answers || []\n  }\n}));"
      },
