# ── Credenciales de la única cuenta de nutricionista ──
NUTRI_EMAIL=correo@dominio.com
NUTRI_PASSWORD=contraseña-segura

# Secreto para firmar la cookie de sesión (cualquier cadena larga aleatoria)
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# ── PostgreSQL (base de negocio) ──
# En el VPS (red interna de Docker): PGHOST=carolina-marino-postgressql-dj2qmg
PGHOST=localhost
PGPORT=5432
PGDATABASE=PostgresSQL
PGUSER=postgres
PGPASSWORD=

# ── Servidor ──
PORT=3001

# ── ManyChat (toggle de bot por cliente) ──
# Token de la API de ManyChat (Settings → API en el panel de ManyChat).
# El panel lo usa para leer/escribir el custom field BotStatus directo,
# sin pasar por n8n. Es el mismo token que ya usa la credencial "Manychat
# API" en n8n — n8n no lo expone vía su API, así que hay que copiarlo desde
# ManyChat (o desde donde se tenga guardado) y pegarlo acá.
MANYCHAT_API_TOKEN=
