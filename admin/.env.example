# ── Credenciales de la única cuenta de nutricionista ──
NUTRI_EMAIL=correo@dominio.com
NUTRI_PASSWORD=contraseña-segura

# Secreto para firmar la cookie de sesión (cualquier cadena larga aleatoria)
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# ── PostgreSQL (base de negocio) ──
# En el VPS (red interna de Docker): PGHOST=carolina-marino-postgressql-dj2qmg
PGHOST=localhost
PGPORT=5432
PGDATABASE=PostgresSQL
PGUSER=postgres
PGPASSWORD=

# ── Servidor ──
PORT=3001
