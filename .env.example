# ── Configuración del sitio de evaluación (quiz) ──
# Copia este archivo a .env y ajusta los valores.
# El .env real está en .gitignore y NO se sube a GitHub.

# Puerto del host donde se publica el sitio (dentro del contenedor siempre es 80)
PORT=8080

# Webhook de n8n que recibe TODAS las respuestas del quiz.
# Se inyecta en runtime en config.js; el navegador hace POST aquí al guardar.
WEBHOOK_URL=https://n8n.caronutriholistica.tech/webhook/fcfad32f-13a7-4148-b2db-e9af457ba77d
